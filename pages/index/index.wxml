<view class="container">
  <view class="header">
    <text class="title">中国象棋·开局大师</text>
    <text class="subtitle">选择开局体系，开始练习</text>
  </view>

  <view class="grid">
    <view
      class="card"
      wx:for="{{categories}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onCategoryTap"
    >
      <text class="card-name">{{item.name}}</text>
      <text class="card-desc">{{item.desc}}</text>
    </view>
  </view>
</view>
