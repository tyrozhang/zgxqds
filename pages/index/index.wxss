.container {
  min-height: 100vh;
  background: #f5f0e8;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 60rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #8B4513;
}

.user-badge {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 8rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.08);
}

.mini-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.mini-name {
  font-size: 24rpx;
  color: #5c3a1e;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-login {
  font-size: 24rpx;
  color: #8B4513;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #a67c52;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.card {
  width: 46%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
  box-sizing: border-box;
  text-align: center;
}

.card-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #5c3a1e;
  margin-bottom: 12rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #a67c52;
}
