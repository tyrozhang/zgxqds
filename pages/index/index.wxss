.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.board-wrapper {
  width: 100%;
  max-width: 750rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.controls {
  margin-top: 30rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.controls button {
  margin: 0;
}

.status {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}
