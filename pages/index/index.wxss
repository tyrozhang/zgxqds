.container {
  min-height: 100vh;
  background: #f5f0e8;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #a67c52;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.card {
  width: 46%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
  box-sizing: border-box;
  text-align: center;
}

.card-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #5c3a1e;
  margin-bottom: 12rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #a67c52;
}
