<view class="container">
  <!-- 讲解模式 -->
  <view wx:if="{{mode === 'explain'}}">
    <!-- 棋盘区域 -->
    <view class="board-wrapper">
      <xiangqiboard
        id="board"
        position="{{position}}"
        orientation="{{orientation}}"
        draggable="{{false}}"
        moveSound="/static/sounds/move.mp3"
        checkSound="/static/sounds/check.mp3"
        bind:beforedrop="onBeforeDrop"
        bind:drop="onBoardDrop"
        bind:moveend="onMoveEnd"
      ></xiangqiboard>
    </view>

    <!-- 讲解内容区 -->
    <view class="explain-content">
      <view class="explain-step-info">
        <text class="step-text">第 {{currentStep}} / {{totalSteps}} 步</text>
      </view>
      <view class="explain-text">
        <text>{{explainContent}}</text>
      </view>
    </view>

    <!-- 讲解控制按钮 -->
    <view class="controls">
      <button size="mini" bindtap="onExplainPrev">上一步</button>
      <button size="mini" bindtap="onExplainNext">下一步</button>
      <button size="mini" bindtap="onExplainRestart">重新开始</button>
    </view>
  </view>

  <!-- 练习模式：选择执红/执黑界面 -->
  <view wx:elif="{{mode === 'practice' && practiceState === 'select'}}" class="practice-select">
    <view class="practice-select-title">请选择练习方式</view>
    <view class="practice-select-buttons">
      <button class="practice-side-btn" bindtap="onSelectPracticeSide" data-side="red">执红练习</button>
      <button class="practice-side-btn" bindtap="onSelectPracticeSide" data-side="black">执黑练习</button>
    </view>
    <view class="practice-hints">
      <text class="hint-text">执红：您走第一步，黑方按棋谱应法</text>
      <text class="hint-text">执黑：AI替您走第一步，您从第二步开始</text>
    </view>
  </view>

  <!-- 练习模式：棋盘区域（始终渲染，但仅在 playing 时显示） -->
  <view wx:elif="{{mode === 'practice' && practiceState === 'playing'}}" class="board-wrapper">
    <xiangqiboard
      id="board"
      position="{{position}}"
      orientation="{{orientation}}"
      draggable="{{true}}"
      moveSound="/static/sounds/move.mp3"
      checkSound="/static/sounds/check.mp3"
      bind:beforedrop="onBeforeDrop"
      bind:drop="onBoardDrop"
      bind:moveend="onMoveEnd"
    ></xiangqiboard>
  </view>

  <!-- 底部信息栏（仅在练习 playing 时显示） -->
  <view wx:if="{{mode === 'practice' && practiceState === 'playing'}}" class="info-bar">
    <text class="turn-text">{{turnText}}</text>
    <text class="status-text" wx:if="{{statusText}}">{{statusText}}</text>
  </view>

  <view wx:if="{{mode === 'practice' && practiceState === 'playing' && allowedMoves.length > 0}}" class="hints">
    <text class="hint-label">当前允许走法：</text>
    <text class="hint-moves">{{allowedMoves.join('、')}}</text>
  </view>

  <view wx:if="{{mode === 'practice' && practiceState === 'playing'}}" class="controls">
    <button size="mini" bindtap="onUndo">悔棋</button>
    <button size="mini" bindtap="onRestart">重新开始</button>
  </view>

  <!-- 底部三按钮 -->
  <view class="bottom-nav">
    <button class="nav-btn {{mode === 'video' ? 'active' : ''}}" bindtap="onSwitchMode" data-mode="video">看视频</button>
    <button class="nav-btn {{mode === 'explain' ? 'active' : ''}}" bindtap="onSwitchMode" data-mode="explain">讲解</button>
    <button class="nav-btn {{mode === 'practice' ? 'active' : ''}}" bindtap="onSwitchMode" data-mode="practice">练习</button>
  </view>
</view>
