.container { padding: 30rpx; }
.user-card {
  background: #fff8e7;
  border: 2rpx solid #d7c49e;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 4rpx solid #b58863; }
.nickname { font-size: 34rpx; color: #3e2723; font-weight: 600; }
