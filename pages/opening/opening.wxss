.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f0e8 0%, #ebe3d5 100%);
}

.category-list {
  padding: 20rpx;
}

.category-item {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(92, 58, 30, 0.08);
  border: 1rpx solid rgba(139, 69, 19, 0.1);
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #8B4513 0%, #a0522d 100%);
  transition: all 0.2s ease;
}

.category-item.expanded .category-header {
  background: linear-gradient(135deg, #6b3410 0%, #8B4513 100%);
  border-bottom: 2rpx solid #5c3a1e;
}

.category-left {
  display: flex;
  align-items: center;
}

.category-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.category-name {
  font-size: 32rpx;
  color: #f5e6d3;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.category-arrow {
  font-size: 24rpx;
  color: #d4a574;
  transition: transform 0.2s ease;
}

.category-item.expanded .category-arrow {
  color: #f5e6d3;
}

.category-content {
  padding: 16rpx;
  background: linear-gradient(180deg, #faf6f0 0%, #fff 100%);
}

.opening-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(92, 58, 30, 0.06);
  border: 1rpx solid rgba(139, 69, 19, 0.08);
  transition: all 0.2s ease;
}

.opening-item:last-child {
  margin-bottom: 0;
}

.opening-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(92, 58, 30, 0.1);
}

.opening-thumb {
  width: 80rpx;
  height: 60rpx;
  margin-right: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f0e8d8 0%, #e8dcc8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d4c4a8;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  font-size: 20rpx;
  color: #a89880;
}

.opening-info {
  flex: 1;
  overflow: hidden;
}

.opening-name {
  font-size: 30rpx;
  color: #3d2b1f;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.opening-desc {
  font-size: 24rpx;
  color: #8b7355;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 24rpx;
  color: #c4a87c;
  margin-left: 16rpx;
}

.empty {
  padding: 40rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #a89880;
}
