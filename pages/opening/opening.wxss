.page {
  min-height: 100vh;
  background: #f5f0e8;
  display: flex;
  flex-direction: column;
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #8B4513;
  color: #fff;
}

.back {
  font-size: 28rpx;
  width: 120rpx;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  flex: 1;
}

.placeholder {
  width: 120rpx;
}

.main {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.sidebar {
  width: 140rpx;
  background: #2d2d2d;
  overflow-y: auto;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 10rpx;
  border-bottom: 1rpx solid #444;
}

.tab-item.active {
  background: #8B4513;
}

.tab-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 8rpx;
}

.tab-name {
  font-size: 22rpx;
  color: #fff;
  text-align: center;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx;
}

.opening-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.opening-thumb {
  width: 80rpx;
  height: 60rpx;
  margin-right: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f0e8d8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  font-size: 20rpx;
  color: #999;
}

.opening-info {
  flex: 1;
  overflow: hidden;
}

.opening-name {
  font-size: 30rpx;
  color: #5c3a1e;
  font-weight: bold;
  display: block;
  margin-bottom: 6rpx;
}

.opening-desc {
  font-size: 24rpx;
  color: #888;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.empty {
  padding: 60rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}
