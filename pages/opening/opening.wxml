<view class="page">
  <view class="main">
    <view class="sidebar">
      <view
        class="tab-item {{selectedCategoryIndex === index ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        data-index="{{index}}"
        bindtap="onSelectCategory"
      >
        <image wx:if="{{item.icon}}" class="tab-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text wx:else class="tab-icon">📂</text>
        <text class="tab-name">{{item.name}}</text>
      </view>
    </view>

    <view class="content">
      <view
        class="opening-item"
        wx:for="{{openings}}"
        wx:key="id"
        data-index="{{index}}"
        bindtap="onSelectOpening"
      >
        <view class="opening-thumb">
          <image
            wx:if="{{item.image}}"
            src="{{item.image}}"
            mode="aspectFill"
            class="thumb-img"
          ></image>
          <view wx:else class="thumb-placeholder">棋谱图</view>
        </view>
        <view class="opening-info">
          <text class="opening-name">{{item.name}}</text>
          <text class="opening-desc">{{item.description || ''}}</text>
        </view>
        <text class="arrow">▶</text>
      </view>
      <view wx:if="{{!openings.length}}" class="empty">暂无数据</view>
    </view>
  </view>
</view>
