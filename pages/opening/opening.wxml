<view class="page">
  <view class="category-list">
    <view
      class="category-item {{expandedCategoryIndex === index ? 'expanded' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
    >
      <view
        class="category-header"
        data-index="{{index}}"
        bindtap="onToggleCategory"
      >
        <view class="category-left">
          <image wx:if="{{item.icon}}" class="category-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <text wx:else class="category-icon">📂</text>
          <text class="category-name">{{item.name}}</text>
        </view>
        <text class="category-arrow">{{expandedCategoryIndex === index ? '▼' : '▶'}}</text>
      </view>

      <view class="category-content" wx:if="{{expandedCategoryIndex === index}}">
        <view
          class="opening-item"
          wx:for="{{openings}}"
          wx:for-item="opening"
          wx:key="id"
          data-index="{{index}}"
          bindtap="onSelectOpening"
        >
          <view class="opening-thumb">
            <image
              wx:if="{{opening.image}}"
              src="{{opening.image}}"
              mode="aspectFill"
              class="thumb-img"
            ></image>
            <view wx:else class="thumb-placeholder">棋谱图</view>
          </view>
          <view class="opening-info">
            <text class="opening-name">{{opening.name}}</text>
            <text class="opening-desc">{{opening.description || ''}}</text>
          </view>
          <text class="arrow">▶</text>
        </view>
        <view wx:if="{{!openings.length}}" class="empty">该分类暂无棋谱</view>
      </view>
    </view>
  </view>
</view>
